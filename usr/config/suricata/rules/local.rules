alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"Possible SSH Brute Force"; flow:established,to_server; content:"SSH-"; threshold:type limit, track by_src, count 5, seconds 60; classtype:attempted-admin; sid:1000001; rev:1;)
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"ICMP Ping Sweep"; dsize:0; itype:8; threshold:type both, track by_src, count 10, seconds 10; classtype:attempted-recon; sid:1000002; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"Suspicious Outbound Connection - Potential Beaconing"; flow:established,to_server; threshold:type limit, track by_src, count 10, seconds 300; classtype:bad-unknown; sid:1000003; rev:1;)
